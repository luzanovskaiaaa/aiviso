# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiviso

# JWT
JWT_SECRET_KEY=replace-with-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
GCS_BUCKET_NAME=aiviso-media

# Vertex AI
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-pro
IMAGE_GEN_MODEL=imagegeneration@006  # заменить после проверки в Model Garden

# Replicate (для удаления фона)
REPLICATE_API_TOKEN=your-replicate-token

# T-Bank (Т-Касса)
TBANK_TERMINAL_KEY=your-terminal-key
TBANK_SECRET_KEY=your-secret-key

# WB API (тест на себе)
WB_API_KEY=your-wb-token

# Ozon API
OZON_CLIENT_ID=your-client-id
OZON_API_KEY=your-api-key
